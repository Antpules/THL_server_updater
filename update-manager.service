[Unit]
Description=Update Manager Service
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/local/update/update-manager.sh
WorkingDirectory=/usr/local/update
Restart=always
RestartSec=10
User=root
Group=root
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Logging
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=update-manager

# Resource limits
LimitNOFILE=4096
LimitNPROC=1024

[Install]
WantedBy=multi-user.target